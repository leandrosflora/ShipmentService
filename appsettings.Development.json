{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "FeatureFlags": {
    "UseMockShipmentRepository": true
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ConsumerGroupId": "shipment-service",
    "Topics": {
      "OrderCreated": "order.created",
      "ShipmentCreated": "shipment.created"
    }
  }
}
